# Backend Environment Variables
DATABASE_URL=postgresql://postgres:password@localhost/kscouts
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Blockchain configuration
# For Sepolia: use your Alchemy/Infura Sepolia RPC URL
# For local Hardhat: use http://127.0.0.1:8545
BLOCKCHAIN_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_api_key_here
CONTRACT_ADDRESS=your_deployed_contract_address_here
WALLET_PRIVATE_KEY=your_wallet_private_key_here
