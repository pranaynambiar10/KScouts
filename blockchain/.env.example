# Blockchain .env — fill these in for Ethereum Sepolia testnet
# For local testing, leave as-is

# Your MetaMask wallet private key (WITHOUT 0x prefix)
# Export from MetaMask → Account Details → Export Private Key
PRIVATE_KEY=your_private_key_here

# Alchemy Sepolia RPC URL
# Create free account at https://alchemy.com → Create App → Ethereum Sepolia
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_api_key_here

# Etherscan API key (for contract verification, optional)
# https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here
