# Blockchain .env — fill these in for Mumbai testnet (Phase 8)
# For local testing, leave as-is

# Your MetaMask wallet private key (WITHOUT 0x prefix)
# Export from MetaMask → Account Details → Export Private Key
PRIVATE_KEY=your_private_key_here

# Alchemy Mumbai RPC URL
# Create free account at https://alchemy.com → Create App → Polygon Mumbai
MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/your_api_key_here

# Polygonscan API key (for contract verification, optional)
# https://polygonscan.com/apis
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
